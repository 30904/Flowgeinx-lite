# Server
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/fglite
JWT_SECRET=your_super_secret_key_here
JWT_REFRESH_SECRET=your_refresh_secret_here
FAST2SMS_KEY=your_fast2sms_api_key
PORT=5000
NODE_ENV=development
ENABLE_REMINDER_JOB=false

# File storage: local (server/templates/) until S3 credentials are ready
STORAGE_MODE=local
FILE_ACCESS_TOKEN=dev-local-token
API_BASE_URL=http://localhost:5000

# AWS S3 (production)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=

# Cloudflare R2 (optional S3-compatible alternative)
R2_ACCOUNT_ID=your_cf_account_id
R2_ACCESS_KEY_ID=your_r2_key
R2_SECRET_ACCESS_KEY=your_r2_secret
R2_BUCKET_NAME=fglite-docs

# WhatsApp
WHATSAPP_TOKEN=your_meta_permanent_access_token
WHATSAPP_PHONE_ID=your_whatsapp_phone_number_id
WA_VERIFY_TOKEN=any_random_string_you_choose

# Razorpay
RAZORPAY_KEY_ID=rzp_test_XXXXXXXX
RAZORPAY_KEY_SECRET=your_secret
RAZORPAY_PLAN_BASIC=plan_XXXXXXXX
RAZORPAY_PLAN_PRO=plan_XXXXXXXX
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Internal AI service (Node calls this — do not expose publicly in prod)
AI_SERVICE_URL=http://localhost:8001

# Python AI Service
# Choose provider: gemini | anthropic
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANTHROPIC_API_KEY=sk-ant-XXXXXXXX
ANTHROPIC_MODEL=claude-sonnet-4-20250514
